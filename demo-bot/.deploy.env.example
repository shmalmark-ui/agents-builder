# Скопируйте в ../.deploy.env (рядом с папкой demo-bot) и заполните.
# Файл .deploy.env НЕ коммитить — он в .gitignore.

# Telegram token от @BotFather
TELEGRAM_TOKEN="YOUR_TELEGRAM_TOKEN_HERE"

# API ключ от LLM-провайдера. По умолчанию настроено под vsegpt.ru (рубли,
# OpenAI-совместимый API, проксирует Claude). Можно подменить на любой
# OpenAI-совместимый эндпоинт (OpenRouter, прямой OpenAI, и т.д.).
LLM_API_KEY="sk-or-vv-..."
LLM_BASE_URL="https://api.vsegpt.ru/v1"
LLM_MODEL="anthropic/claude-sonnet-4.6"

# Telegram username владельца — куда летят лиды (без @)
OWNER_USERNAME="YOUR_USERNAME_WITHOUT_AT"

# SSH-юзер@хост сервера
COOLIFY_SERVER="root@5.42.117.7"
